{
  "name": "graphql-client-boilerplate",
  "version": "0.0.1",
  "description": "This GraphQL client boilerplate provides a basic structure for building clients to connect to graphql servers.",
  "repository": "git@github.com:Innovixx/graphql-server-boilerplate.git",
  "author": "Innovixx <support@innovixx.co.uk>",
  "scripts": {
    "dev": "concurrently \"pnpm watch:generate-types:styles\" \"vite\" --hide=0",
    "build": "tsc && vite build",
    "preview": "vite preview --port 3000",
    "codegen": "cross-env TS_NODE_PROJECT=tsconfig.codegen.json graphql-codegen --config codegen.ts",
    "lint-staged": "lint-staged --verbose",
    "lint": "eslint ./src/**/*.{js,jsx,ts,tsx,graphql}",
    "stylelint": "stylelint \"**/*.scss\"",
    "generate-types:styles": "typed-scss-modules src --outputFolder src/types/styles",
    "watch:generate-types:styles": "pnpm generate-types:styles --watch --logLevel=silent",
    "prepare": "if [ -d node_modules/husky ]; then husky; fi"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "graphql": "^16.14.0",
    "graphql-tag": "^2.12.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@apollo/client": "^4.1.9",
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-codegen/typescript-operations": "^6.0.1",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@graphql-eslint/eslint-plugin": "^4.4.0",
    "@innovixx/eslint-config": "^3.0.12",
    "@innovixx/stylelint-config": "^1.0.8",
    "@types/color": "^4.2.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "eslint": "9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "stylelint": "^17.11.0",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-prettier": "^5.0.3",
    "stylelint-scss": "^7.0.0",
    "typed-scss-modules": "^8.1.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.11"
  },
  "lint-staged": {
    "**/*.scss": "stylelint",
    "**/*.graphql": "eslint",
    "**/*.{js,ts,jsx,tsx}": [
      "eslint --quiet",
      "bash -c tsc"
    ]
  }
}